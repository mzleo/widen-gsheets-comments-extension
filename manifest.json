{
  "manifest_version": 3,
  "name": "Widen Gsheets Comments Extension",
  "version": "1.0.0",
  "description": "Horizontal Comment Widener for Google Sheets",
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
